{
    "name": "zxf/captcha",
    "description": "一个通用的、高性能的 PHP 滑动验证码扩展包，支持 Laravel、ThinkPHP、Yii 等主流框架",
    "type": "library",
    "keywords": [
        "captcha",
        "slide-captcha",
        "tncode",
        "verify",
        "security",
        "validation",
        "laravel",
        "thinkphp",
        "yii",
        "php8"
    ],
    "homepage": "https://github.com/zhaoxianfang/captcha",
    "license": "MIT",
    "authors": [
        {
            "name": "zhaoxianfang",
            "email": "zhaoxianfang@163.com",
            "homepage": "https://weisifang.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-gd": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-redis": "如需使用 Redis 存储验证码数据",
        "laravel/framework": "如需使用 Laravel 框架集成",
        "topthink/framework": "如需使用 ThinkPHP 框架集成",
        "yiisoft/yii2": "如需使用 Yii 框架集成"
    },
    "autoload": {
        "psr-4": {
            "zxf\\Captcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "zxf\\Captcha\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "zxf\\Captcha\\Adapters\\Laravel\\CaptchaServiceProvider"
            ],
            "aliases": {
                "Captcha": "zxf\\Captcha\\Adapters\\Laravel\\CaptchaFacade"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
